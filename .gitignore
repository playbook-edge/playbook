# Environment variables — never commit real API keys
.env

# Python cache files
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environment
venv/
env/
.venv/

# Logs
logs/*.log

# Data files (can be large)
data/raw/*
data/processed/*
data/historical/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/historical/.gitkeep
# Historical season stats are static (seasons are over) — commit them so Railway never re-fetches
!data/historical/pitcher_stats_2024.csv
!data/historical/pitcher_stats_2025.csv
!data/historical/pitcher_stats_all.csv

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
