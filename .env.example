# ============================================================
# PLAYBOOK — Environment Variable Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.
# ============================================================

# --- Claude AI (Anthropic) ---
# Used to analyze games and generate betting insights
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Supabase (Database) ---
# Stores historical data, model outputs, and bet tracking
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --- Discord Alerts ---
# General webhook (legacy)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
# Channel for conservative (4%+ EV) alerts — this is the main one used by the bot
DISCORD_WEBHOOK_CONSERVATIVE=https://discord.com/api/webhooks/your_webhook_here
# Channel for paper trading tracking — logs every simulated bet and running P&L
DISCORD_WEBHOOK_PAPER=https://discord.com/api/webhooks/your_webhook_here
# Channel for pipeline health and system status — KEEP THIS SEPARATE from bet channels
DISCORD_WEBHOOK_HEALTH=https://discord.com/api/webhooks/your_webhook_here

# --- Odds API ---
# Source for live betting lines and odds
ODDS_API_KEY=your_odds_api_key_here

# --- General Settings ---
# Which sport to focus on (e.g. baseball, basketball)
SPORT=baseball_mlb
# Minimum edge % to trigger a bet alert (e.g. 5 = 5%)
MIN_EDGE_PERCENT=5
# Bankroll size in dollars for Kelly sizing
BANKROLL=1000

# ============================================================
# Railway Services
# ============================================================
# Three cron services run on Railway — set the same env vars in each service's
# settings panel (all three share the same repo and the same set of keys above).
#
# playbook         — python main.py           — cron: 30 14 * * *  (10:30 AM ET)
#   Full daily pipeline: scrape → model → EV → Discord alerts → paper trades
#
# playbook-resolve — python alerts/paper_trading.py auto_resolve
#                  — cron: 30 3 * * *   (11:30 PM ET)
#   Resolves PENDING paper trades against MLB box scores, sends P&L to Discord.
#
# playbook-snapshot — python scrapers/odds_api.py snapshot
#                   — cron: 30 22 * * *  (6:30 PM ET)
#   Takes a game-day odds snapshot for all games starting within 3 hours, then
#   runs line movement calculation to compare opening vs pre-game lines.
#   Output: data/raw/props_gameday_snapshot.csv + Supabase line_movement table.
